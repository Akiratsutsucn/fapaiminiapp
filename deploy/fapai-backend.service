[Unit]
Description=法拍者联盟 FastAPI Backend
After=network.target mysql.service
Wants=mysql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/fapai/backend
EnvironmentFile=/opt/fapai/.env
ExecStart=/opt/fapai/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 25081 --workers 4
Restart=always
RestartSec=5
StandardOutput=append:/var/log/fapai/backend.log
StandardError=append:/var/log/fapai/backend-error.log

[Install]
WantedBy=multi-user.target
