# 法拍者联盟 · 环境变量示例
# 用法：cp .env.example .env，然后填实际值

# ===== 数据库 =====
DB_TYPE=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=fapai
DB_PASSWORD=YOUR_DB_PASSWORD
DB_NAME=shanghai_fapai

# ===== 微信小程序 =====
WECHAT_APPID=wxXXXXXXXXXXXXXXXX
WECHAT_APPSECRET=YOUR_APPSECRET
WECHAT_ENV_VERSION=trial

# ===== 微信公众号（拍来盟科技，已认证服务号）=====
# 用于把公众号已群发文章同步到「文章管理」。
# 重要：调用前需把生产服务器出口 IP 加入公众号后台「设置与开发 > 基本配置 > IP白名单」。
WECHAT_MP_APPID=
WECHAT_MP_APPSECRET=

# ===== JWT =====
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_LONG_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=35
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== 高德地图 =====
AMAP_API_KEY=YOUR_AMAP_KEY

# ===== 三平台爬虫 cookie =====
# 阿里司法拍卖（sf.taobao.com / pages-fast.m.taobao.com）
TAOBAO_COOKIE=""
# 京东司法拍卖（默认 anonymous，留空即可）
# JD_COOKIE=""
# 公拍网
GPAI_COOKIE=""
# 贝壳找房
BEIKE_COOKIE=""

# ===== 三平台爬虫账号（用于自动登录脚本）=====
# 阿里
TAOBAO_USER=
TAOBAO_PASS=
# 公拍
GPAI_USER=
GPAI_PASS=
# 贝壳
BEIKE_USER=
BEIKE_PASS=

# ===== 抗封堵 =====
# 多个住宅代理用逗号分隔（推荐 50 元/月 套餐）
# PROXY_POOL=http://user:pass@1.2.3.4:8888,socks5://5.6.7.8:1080
PROXY_POOL=

# 隧道代理换 IP（如 90daili 隧道：入口固定，出口可换）
# 撞风控时主动调此接口换一个新出口 IP，而不是冷却唯一的入口
# TUNNEL_IP_CHANGE_URL=http://api.90daili.com/api/v3/triggerTunnelIpChange?uid=xxx&id=yyy
TUNNEL_IP_CHANGE_URL=
# 两次主动换 IP 的最小间隔（秒），避免频繁调用被限流
TUNNEL_IP_CHANGE_MIN_INTERVAL=30

# ===== 图片存储 =====
IMAGE_STORAGE_PATH=/picture
IMAGE_BASE_URL=

# ===== 调度 =====
SCHEDULER_ENABLED=true
DAILY_CRON="0 2 * * *"
