<view class="tab-bar">
  <view class="tab-bar-border"></view>

  <!-- 首页 -->
  <view class="tab-item" data-index="0" data-path="/pages/index/index" bindtap="switchTab">
    <image class="tab-icon" src="{{selected === 0 ? '/images/tab-home-active.png' : '/images/tab-home.png'}}" />
    <text class="tab-text {{selected === 0 ? 'active' : ''}}">首页</text>
  </view>

  <!-- 中间：AI选房 -->
  <view class="tab-center" bindtap="onAiSelect">
    <view class="ai-btn">
      <text class="ai-btn-text">AI选房</text>
    </view>
  </view>

  <!-- 我的 -->
  <view class="tab-item" data-index="1" data-path="/pages/mine/mine" bindtap="switchTab">
    <image class="tab-icon" src="{{selected === 1 ? '/images/tab-mine-active.png' : '/images/tab-mine.png'}}" />
    <text class="tab-text {{selected === 1 ? 'active' : ''}}">我的</text>
  </view>
</view>
