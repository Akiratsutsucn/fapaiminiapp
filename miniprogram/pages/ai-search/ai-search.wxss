.ai-search-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 32rpx;
}

.as-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.as-icon {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 16rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.as-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1a2f52;
  margin-bottom: 8rpx;
}

.as-subtitle {
  display: block;
  font-size: 24rpx;
  color: #8a8a8a;
}

.as-input-wrap {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.as-input {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  line-height: 44rpx;
  color: #333;
}

.as-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.as-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.as-btn-voice {
  background: #f0f0f0;
  color: #666;
}

.as-btn-voice.recording {
  background: #ff6b35;
  color: #fff;
}

.as-btn-search {
  background: #ff6b35;
  color: #fff;
}

.voice-icon {
  width: 32rpx;
  height: 32rpx;
  background: currentColor;
}

.as-examples {
  margin-bottom: 32rpx;
}

.as-examples-title {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.as-example-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.as-tag {
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #666;
}

.as-parsed {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.as-parsed-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.as-parsed-items {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.as-parsed-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
}

.as-parsed-item .label {
  font-size: 24rpx;
  color: #999;
}

.as-parsed-item .value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.as-results-header {
  margin-bottom: 24rpx;
}

.as-results-count {
  font-size: 28rpx;
  color: #666;
}

.as-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.as-empty {
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
  color: #999;
}

/* 合规提示：AI 生成内容声明（常驻页面底部） */
.as-ai-notice {
  margin-top: 48rpx;
  padding: 24rpx 32rpx 40rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.as-ai-notice-main {
  font-size: 28rpx;
  color: #8a8d92;
  font-weight: 500;
  letter-spacing: 1rpx;
}
.as-ai-notice-sub {
  font-size: 22rpx;
  color: #b0b3b8;
  letter-spacing: 0.5rpx;
  line-height: 1.4;
}

/* 联系方式门禁弹窗 */
.contact-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.contact-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  box-sizing: border-box;
}
.contact-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
}
.contact-tip {
  font-size: 26rpx;
  color: #8a8a8a;
  margin-top: 16rpx;
  margin-bottom: 32rpx;
  line-height: 1.5;
}
.contact-field {
  margin-bottom: 28rpx;
}
.contact-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.contact-req {
  color: #ff4d4f;
}
.contact-input {
  width: 100%;
  height: 84rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
}
.contact-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}
.contact-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  padding: 0;
}
.contact-btn-cancel {
  background: #f0f0f0;
  color: #666;
}
.contact-btn-ok {
  background: #ff6b35;
  color: #fff;
}
.contact-btn-ok::after,
.contact-btn-cancel::after {
  border: none;
}
