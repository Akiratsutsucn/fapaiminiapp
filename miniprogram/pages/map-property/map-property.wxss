.page {
  position: relative;
  width: 100vw;
  height: 100vh;
}

.map {
  width: 100%;
  height: 100%;
}

.map-controls {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ctrl-btn {
  width: 72rpx;
  height: 72rpx;
  background: var(--bg-card);
  border-radius: 50%;
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-btn-text {
  font-size: 44rpx;
  font-weight: 500;
  color: var(--blue-800);
  line-height: 1;
}

.ctrl-btn-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 底部房源卡片 */
.bottom-card {
  position: fixed;
  bottom: var(--spacing-md);
  left: var(--spacing-md);
  right: var(--spacing-md);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  padding: var(--spacing-md);
  z-index: 10;
}

.bc-close {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 11;
}

.bc-close-icon {
  width: 28rpx;
  height: 28rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  opacity: 0.7;
}

.bc-row {
  display: flex;
  gap: var(--spacing-md);
}

.bc-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--bg-page);
}

.bc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.bc-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bc-location {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.bc-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bc-price {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--warning);
}

.bc-status {
  font-size: var(--font-xs);
  color: var(--blue-600);
  background: var(--blue-100);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
