.page {
  position: relative;
  width: 100vw;
  height: 100vh;
}

.map {
  width: 100%;
  height: 100%;
}

/* ===== 顶部筛选栏 ===== */
.map-filter-bar {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 20;
  display: flex;
  gap: 16rpx;
}

.mf-chip {
  flex: 1;
  height: 72rpx;
  background: var(--bg-card);
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 28rpx;
  color: var(--blue-800);
  font-weight: 600;
}

.mf-chip.active {
  color: var(--accent-orange-text);
  background: #fff;
}

.mf-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid currentColor;
}

.mf-panel {
  position: absolute;
  top: 112rpx;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 19;
}

.mf-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.35);
}

.mf-options {
  position: relative;
  background: var(--bg-card);
  margin: 0 20rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  padding: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.mf-opt {
  padding: 12rpx 28rpx;
  background: var(--blue-50);
  color: var(--blue-700);
  border-radius: var(--radius-pill);
  font-size: 26rpx;
}

.mf-opt.sel {
  background: var(--blue-900);
  color: #fff;
  font-weight: 600;
}

.map-controls {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ctrl-btn {
  width: 72rpx;
  height: 72rpx;
  background: var(--bg-card);
  border-radius: 50%;
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ctrl-btn-text {
  font-size: 48rpx;
  font-weight: 400;
  color: var(--blue-800);
  line-height: 72rpx;
  text-align: center;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 4rpx;
  box-sizing: border-box;
}

.ctrl-btn-icon {
  width: 40rpx;
  height: 40rpx;
}

/* 底部房源卡片 */
.bottom-card {
  position: fixed;
  bottom: var(--spacing-md);
  left: var(--spacing-md);
  right: var(--spacing-md);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  padding: var(--spacing-md);
  z-index: 10;
}

.bc-close {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 11;
}

.bc-close-icon {
  width: 28rpx;
  height: 28rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  opacity: 0.7;
}

.bc-row {
  display: flex;
  gap: var(--spacing-md);
}

.bc-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--bg-page);
}

.bc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.bc-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bc-location {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.bc-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bc-price {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--warning);
}

.bc-status {
  font-size: var(--font-xs);
  color: var(--blue-600);
  background: var(--blue-100);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
