.page {
  position: relative;
  width: 100vw;
  height: 100vh;
}

.map {
  width: 100%;
  height: 100%;
}

/* ===== 关键字搜索栏 ===== */
.map-search-bar {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 21;
}
.ms-input-wrap {
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #fff;
  border-radius: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.12);
  padding: 0 24rpx;
}
.ms-search-icon {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #999;
  border-radius: 50%;
  position: relative;
  flex-shrink: 0;
  margin-right: 12rpx;
}
.ms-search-icon::after {
  content: '';
  position: absolute;
  right: -8rpx;
  bottom: -6rpx;
  width: 12rpx;
  height: 3rpx;
  background: #999;
  transform: rotate(45deg);
}
.ms-input {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}
.ms-clear {
  width: 36rpx;
  height: 36rpx;
  line-height: 32rpx;
  text-align: center;
  color: #999;
  font-size: 32rpx;
}

/* ===== 顶部筛选栏 ===== */
.map-filter-bar {
  position: absolute;
  top: 108rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 20;
  white-space: nowrap;
}
.map-filter-bar .mf-chip {
  display: inline-flex;
  flex: none;
  width: auto;
  padding: 0 24rpx;
  margin-right: 16rpx;
  vertical-align: top;
}

/* ===== 图例 ===== */
.map-legend {
  position: absolute;
  left: 20rpx;
  bottom: 40rpx;
  z-index: 20;
  background: rgba(255,255,255,0.95);
  border-radius: 12rpx;
  padding: 12rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.lg-item { display: flex; align-items: center; font-size: 22rpx; color: #555; }
.lg-dot { width: 18rpx; height: 18rpx; border-radius: 50%; margin-right: 8rpx; }
.lg-red { background: #E53935; }
.lg-blue { background: #1E88E5; }
.lg-gray { background: #787880; }

/* ===== 顶部筛选栏(原) ===== */
.map-filter-bar-legacy {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  right: 20rpx;
  z-index: 20;
  display: flex;
  gap: 16rpx;
}

.mf-chip {
  flex: 1;
  height: 72rpx;
  background: var(--bg-card);
  border-radius: var(--radius-pill);
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 28rpx;
  color: var(--blue-800);
  font-weight: 600;
}

.mf-chip.active {
  color: var(--accent-orange-text);
  background: #fff;
}

.mf-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid currentColor;
}

.mf-panel {
  position: absolute;
  top: 196rpx;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 19;
}

.mf-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.35);
}

.mf-options {
  position: relative;
  background: var(--bg-card);
  margin: 0 20rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  padding: 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.mf-opt {
  padding: 12rpx 28rpx;
  background: var(--blue-50);
  color: var(--blue-700);
  border-radius: var(--radius-pill);
  font-size: 26rpx;
}

.mf-opt.sel {
  background: var(--blue-900);
  color: #fff;
  font-weight: 600;
}

/* 地图缩放全程用手势操作,已移除侧边 +/-/定位 按钮 */

/* 底部房源卡片 */
.bottom-card {
  position: fixed;
  bottom: var(--spacing-md);
  left: var(--spacing-md);
  right: var(--spacing-md);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-lg);
  padding: var(--spacing-md);
  z-index: 10;
}

.bc-close {
  position: absolute;
  top: 12rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 11;
}

.bc-close-icon {
  width: 28rpx;
  height: 28rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  opacity: 0.7;
}

.bc-row {
  display: flex;
  gap: var(--spacing-md);
}

.bc-cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--bg-page);
}

.bc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.bc-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bc-location {
  font-size: var(--font-xs);
  color: var(--text-hint);
}

.bc-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.bc-price {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--warning);
}

.bc-status {
  font-size: var(--font-xs);
  color: var(--blue-600);
  background: var(--blue-100);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
