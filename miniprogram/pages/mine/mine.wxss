.mine-page {
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  background: var(--bg-page);
  min-height: 100vh;
}

.mine-header {
  position: relative;
  padding-top: 40rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: -60rpx;
  left: 0;
  right: 0;
  height: 480rpx;
  background: linear-gradient(160deg, var(--blue-900) 0%, var(--blue-800) 50%, var(--blue-700) 100%);
}

.header-bg::after {
  content: '';
  position: absolute;
  right: -120rpx;
  top: -100rpx;
  width: 460rpx;
  height: 460rpx;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.18) 0%, transparent 70%);
  border-radius: 50%;
}

.header-content {
  position: relative;
  display: flex;
  align-items: center;
  padding: 36rpx 32rpx 60rpx;
}

.avatar-wrap {
  width: 132rpx;
  height: 132rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 4rpx solid rgba(255,255,255,0.25);
  margin-right: 28rpx;
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar {
  width: 100%;
  height: 100%;
  display: block;
}

.avatar-btn {
  width: 100%;
  height: 100%;
  padding: 0;
  margin: 0;
  line-height: normal;
  background: transparent;
  border-radius: 0;
  position: relative;
  display: block;
}

.avatar-btn::after {
  border: none;
}

.avatar-edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: var(--accent-orange);
  border: 3rpx solid #fff;
  box-sizing: border-box;
}

.avatar-edit-badge::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16rpx;
  height: 16rpx;
  transform: translate(-50%, -50%);
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
}

.user-info { flex: 1; min-width: 0; }

.user-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.user-name {
  font-size: 40rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.5rpx;
}

.role-tag {
  background: var(--accent-orange);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-pill);
  letter-spacing: 1rpx;
  font-weight: 700;
  box-shadow: 0 2rpx 8rpx rgba(255, 107, 53, 0.4);
}

.user-phone {
  display: block;
  font-size: 24rpx;
  color: var(--blue-200);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

.login-entry {
  display: flex;
  align-items: center;
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
}

.entry-arrow {
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 12rpx solid rgba(255,255,255,0.7);
  margin-left: 12rpx;
}

/* ===== 统计行 ===== */
.stats-row {
  display: flex;
  align-items: center;
  margin: -32rpx 24rpx 16rpx;
  padding: 28rpx 16rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-elevated);
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: var(--blue-900);
  letter-spacing: -1rpx;
  font-variant-numeric: tabular-nums;
  line-height: 1.1;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(58, 90, 140, 0.12);
}

/* ===== 服务宫格 ===== */
.service-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  padding: 12rpx 24rpx 24rpx;
}

.service-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 16rpx 28rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
}

.service-item::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--blue-50);
  border-radius: 50%;
  opacity: 0.6;
}

.service-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 14rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  position: relative;
  z-index: 1;
}

.service-name {
  font-size: 24rpx;
  color: var(--blue-900);
  font-weight: 600;
  position: relative;
  z-index: 1;
}

