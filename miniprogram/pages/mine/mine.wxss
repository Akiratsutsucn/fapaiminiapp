.rec-dot {
  position: absolute;
  top: 2rpx;
  right: 18rpx;
  min-width: 56rpx;
  height: 56rpx;
  padding: 0 16rpx;
  background: var(--accent-orange);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}

/* 编辑弹窗 */
.edit-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.edit-modal {
  width: 640rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.edit-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.edit-modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.edit-close {
  font-size: 44rpx;
  color: #999;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit-modal-body {
  padding: 32rpx 36rpx 8rpx;
}

.edit-field {
  margin-bottom: 28rpx;
}

.edit-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
}

.edit-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  border: 1rpx solid #d0d0d0;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background-color: #fafafa;
}

.edit-input:focus {
  border-color: var(--blue-600);
  background-color: #fff;
}

.edit-modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 24rpx 36rpx 32rpx;
}

.edit-cancel {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  color: #666;
  border: none;
  padding: 0;
}

.edit-cancel::after {
  border: none;
}

.edit-save {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  border-radius: 8rpx;
  border: none;
  padding: 0;
}

.edit-save::after {
  border: none;
}

/* ===== 区段标题（V2） ===== */
.section-head {
  padding: 24rpx 24rpx 16rpx;
  display: flex;
  align-items: baseline;
  justify-content: space-between;
}

.section-title-v2 {
  font-size: 32rpx;
  font-weight: 800;
  color: var(--blue-900);
  letter-spacing: -0.5rpx;
}

/* ===== 推广位 ===== */
.promo-card {
  margin: 24rpx 24rpx 16rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, var(--blue-900) 0%, var(--blue-700) 100%);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.promo-card::after {
  content: '';
  position: absolute;
  right: -50rpx;
  top: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.22) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.promo-text {
  flex: 1;
  position: relative;
  z-index: 1;
}

.promo-tag {
  display: inline-block;
  background: var(--accent-orange);
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: var(--radius-sm);
  font-weight: 800;
  letter-spacing: 1rpx;
  margin-bottom: 10rpx;
}

.promo-title {
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 6rpx;
  letter-spacing: -0.5rpx;
}

.promo-sub {
  font-size: 22rpx;
  color: var(--blue-200);
}

.promo-arrow {
  font-size: 48rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
  margin-left: 16rpx;
  position: relative;
  z-index: 1;
}
