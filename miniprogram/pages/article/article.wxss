.article-page {
  padding-bottom: 200rpx;
  background: var(--bg-page);
  min-height: 100vh;
}

.article-cover {
  width: 100%;
  height: 460rpx;
  background: var(--blue-100);
}

.article-header {
  background: var(--bg-card);
  margin: -32rpx 24rpx 16rpx;
  border-radius: var(--radius-lg);
  padding: 32rpx 28rpx;
  position: relative;
  z-index: 2;
  box-shadow: var(--shadow-card);
}

.article-title {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.4;
  color: var(--blue-900);
  letter-spacing: -1rpx;
  display: block;
}

.article-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  align-items: center;
}

.meta-item {
  font-size: 22rpx;
  color: var(--text-hint);
  letter-spacing: 0.5rpx;
}

.meta-item:first-child {
  background: var(--accent-orange-soft);
  color: var(--accent-orange-text);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-pill);
  font-weight: 700;
}

.article-body {
  margin: 0 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
}

.article-summary {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.85;
  text-indent: 2em;
}

.article-content {
  display: block;
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.85;
  word-break: break-word;
}

.article-link {
  display: flex;
  align-items: center;
  margin-top: 28rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, var(--blue-50) 0%, #fff 100%);
  border-left: 6rpx solid var(--accent-orange);
  border-radius: var(--radius-md);
  color: var(--blue-900);
  font-size: 26rpx;
  font-weight: 600;
}

.link-arrow {
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 12rpx solid var(--accent-orange);
  margin-left: 12rpx;
}

/* ===== 公众号底栏（V2） ===== */
.mp-footer {
  display: flex;
  align-items: center;
  margin: 24rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, var(--blue-900) 0%, var(--blue-700) 100%);
  border-radius: var(--radius-lg);
  gap: 16rpx;
  position: relative;
  overflow: hidden;
  box-shadow: var(--shadow-elevated);
}

.mp-footer::after {
  content: '';
  position: absolute;
  right: -50rpx;
  top: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.18) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.mp-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  padding: 6rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.mp-info {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  position: relative;
  z-index: 1;
}

.mp-name {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  color: #fff;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: 0.5rpx;
}

.mp-desc {
  display: block;
  font-size: 22rpx;
  color: var(--blue-200);
  margin-top: 4rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.btn-sm {
  padding: 10rpx 24rpx;
  font-size: 22rpx;
  height: 56rpx;
  line-height: 36rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  color: #fff;
  border: none;
  font-weight: 800;
  letter-spacing: 1rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.4);
}

.mp-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}

.mp-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  padding: 8rpx 6rpx;
  min-width: 60rpx;
}

.mp-icon {
  width: 36rpx;
  height: 36rpx;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.mp-follow-btn {
  flex-shrink: 0;
}

.mp-icon-like {
  background-image: url("data:image/svg+xml;base64,");
}

.mp-icon-like.active {
  background-image: url("data:image/svg+xml;base64,");
}

.mp-icon-msg {
  background-image: url("data:image/svg+xml;base64,");
}

.mp-action-label {
  font-size: 20rpx;
  color: var(--blue-200);
}
