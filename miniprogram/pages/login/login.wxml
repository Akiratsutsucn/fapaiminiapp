<view class="login-page">
  <!-- 装饰圈 -->
  <view class="login-bg">
    <view class="bg-glow"></view>
    <view class="bg-circle circle-1"></view>
    <view class="bg-circle circle-2"></view>
    <view class="bg-circle circle-3"></view>
    <!-- 2026世界杯 文字装饰（右下角，倾斜，半透明） -->
    <image class="wc-text" src="/images/wc-2026-text.png" mode="aspectFit" />
  </view>

  <!-- 顶部品牌 -->
  <view class="login-brand">
    <view class="brand-logo-wrap">
      <image class="brand-logo" src="/images/logo.png" mode="aspectFit" />
    </view>
    <view class="brand-text">
      <text class="brand-name">法拍者联盟</text>
      <text class="brand-subtitle">FAPAI · 立足长三角地区 辐射全国法拍市场</text>
    </view>
  </view>

  <!-- Hero 大字报 -->
  <view class="login-hero">
    <view class="hero-tagline">JUDICIAL AUCTION · INSIDER</view>
    <view class="hero-title">做<text class="accent">专业</text>的</view>
    <view class="hero-title-2">法拍主理</view>
    <view class="hero-sub">同步自 阿里 · 京东 · 公拍 等权威平台房源数据</view>
  </view>

  <!-- 数据小卡 -->
  <view class="login-stats">
    <view class="ls-cell">
      <text class="ls-num">{{summary.onAuctionText}}</text>
      <text class="ls-label">在拍房源</text>
    </view>
    <view class="ls-divider"></view>
    <view class="ls-cell">
      <text class="ls-num">{{summary.bargain}}</text>
      <text class="ls-label">捡漏推荐</text>
    </view>
    <view class="ls-divider"></view>
    <view class="ls-cell">
      <text class="ls-num accent">{{summary.discountText}}</text>
      <text class="ls-label">平均折扣</text>
    </view>
  </view>

  <!-- 登录区 -->
  <view class="login-actions">
    <button class="login-btn" bindtap="onLogin" loading="{{loading}}">
      <view class="login-btn-content">
        <view class="login-btn-icon wechat-icon"></view>
        <text class="login-btn-text">一键登录</text>
      </view>
    </button>

    <view class="privacy-agreement" bindtap="onAgreeToggle">
      <view class="privacy-checkbox {{agreed ? 'checked' : ''}}">
        <text wx:if="{{agreed}}" class="privacy-check-mark">✓</text>
      </view>
      <text class="privacy-text">
        已阅读并同意<text class="privacy-link" catchtap="onViewTerms">《用户协议》</text>和<text class="privacy-link" catchtap="onViewPrivacy">《隐私政策》</text>
      </text>
    </view>
  </view>

  <view class="login-footer">
    <text class="footer-disclaimer">本平台所载法拍房源信息均来自人民法院诉讼资产网、阿里资产·司法拍卖、京东司法拍卖、公拍网等公开渠道，仅供参考，不构成任何投资或交易建议。竞买请以各拍卖平台及法院公告的官方信息为准，平台不对信息的完整性、准确性、时效性承担法律责任。</text>
    <text class="footer-text">© 拍来盟科技 · 客服 400-007-6786</text>
    <text class="footer-icp" catchtap="onViewICP">{{icpNumber}}</text>
    <text class="footer-icp" catchtap="onViewPolice">{{policeNumber}}</text>
  </view>
</view>
