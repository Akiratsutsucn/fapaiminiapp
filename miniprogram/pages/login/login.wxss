.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, var(--blue-900) 0%, var(--blue-800) 35%, var(--blue-700) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 120rpx 48rpx 60rpx;
  box-sizing: border-box;
}

.login-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.bg-glow {
  position: absolute;
  top: -120rpx;
  right: -160rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.22) 0%, transparent 70%);
  border-radius: 50%;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: 80rpx;
  right: -80rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: 280rpx;
  left: -100rpx;
}

.circle-3 {
  width: 200rpx;
  height: 200rpx;
  bottom: -50rpx;
  right: 60rpx;
}

/* ===== 美加墨世界杯氛围装饰（原创 SVG，非 FIFA 官方资产） ===== */
/* 右上角彩旗串：美/加/墨三国旗色三角旗，微旋斜挂，避开左侧品牌名 */
.wc-bunting {
  position: absolute;
  top: 96rpx;
  right: -40rpx;
  width: 58%;
  height: 128rpx;
  transform: rotate(6deg);
  opacity: 0.9;
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%20300%2060%22%20preserveAspectRatio%3D%22none%22%3E%3Cpath%20d%3D%22M0%2C10%20Q150%2C22%20300%2C10%22%20stroke%3D%22rgba%28255%2C255%2C255%2C.45%29%22%20stroke-width%3D%221.5%22%20fill%3D%22none%22%2F%3E%3Cpolygon%20points%3D%220%2C10%2025%2C10%2013%2C32%22%20fill%3D%22%23B22234%22%2F%3E%3Cpolygon%20points%3D%2225%2C12%2050%2C12%2038%2C34%22%20fill%3D%22%23ffffff%22%2F%3E%3Cpolygon%20points%3D%2250%2C14%2075%2C14%2063%2C36%22%20fill%3D%22%233C3B6E%22%2F%3E%3Cpolygon%20points%3D%2275%2C16%20100%2C16%2088%2C38%22%20fill%3D%22%23006847%22%2F%3E%3Cpolygon%20points%3D%22100%2C17%20125%2C17%20113%2C39%22%20fill%3D%22%23ffffff%22%2F%3E%3Cpolygon%20points%3D%22125%2C18%20150%2C18%20138%2C40%22%20fill%3D%22%23CE1126%22%2F%3E%3Cpolygon%20points%3D%22150%2C18%20175%2C18%20163%2C40%22%20fill%3D%22%23FF0000%22%2F%3E%3Cpolygon%20points%3D%22175%2C18%20200%2C18%20188%2C40%22%20fill%3D%22%23ffffff%22%2F%3E%3Cpolygon%20points%3D%22200%2C17%20225%2C17%20213%2C39%22%20fill%3D%22%23B22234%22%2F%3E%3Cpolygon%20points%3D%22225%2C16%20250%2C16%20238%2C38%22%20fill%3D%22%23ffffff%22%2F%3E%3Cpolygon%20points%3D%22250%2C14%20275%2C14%20263%2C36%22%20fill%3D%22%233C3B6E%22%2F%3E%3Cpolygon%20points%3D%22275%2C12%20300%2C12%20288%2C34%22%20fill%3D%22%23006847%22%2F%3E%3C%2Fsvg%3E");
  background-size: 100% 100%;
  background-repeat: no-repeat;
}

/* 右下角足球：经典黑白，低透明度融入蓝底 */
.wc-ball {
  position: absolute;
  width: 320rpx;
  height: 320rpx;
  bottom: 60rpx;
  right: -60rpx;
  opacity: 0.2;
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%20100%20100%22%3E%3Ccircle%20cx%3D%2250%22%20cy%3D%2250%22%20r%3D%2248%22%20fill%3D%22%23fff%22%20stroke%3D%22%231a2f52%22%20stroke-width%3D%221.5%22%2F%3E%3Cpolygon%20points%3D%2250%2C26%2068%2C40%2061%2C62%2039%2C62%2032%2C40%22%20fill%3D%22%231a2f52%22%2F%3E%3Cpolygon%20points%3D%2250%2C4%2060%2C12%2050%2C22%2040%2C14%22%20fill%3D%22%231a2f52%22%2F%3E%3Cpolygon%20points%3D%2290%2C38%2092%2C52%2078%2C52%2080%2C40%22%20fill%3D%22%231a2f52%22%2F%3E%3Cpolygon%20points%3D%2274%2C86%2062%2C80%2070%2C68%2082%2C74%22%20fill%3D%22%231a2f52%22%2F%3E%3Cpolygon%20points%3D%2226%2C86%2038%2C80%2030%2C68%2018%2C74%22%20fill%3D%22%231a2f52%22%2F%3E%3Cpolygon%20points%3D%2210%2C38%208%2C52%2022%2C52%2020%2C40%22%20fill%3D%22%231a2f52%22%2F%3E%3C%2Fsvg%3E");
  background-size: 100% 100%;
  background-repeat: no-repeat;
}

/* 底部球场弧线：极低透明度铺底，暗示绿茵场 */
.wc-pitch {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 400rpx;
  opacity: 0.1;
  background-image: url("data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%20300%20200%22%20preserveAspectRatio%3D%22none%22%3E%3Ccircle%20cx%3D%22150%22%20cy%3D%22240%22%20r%3D%22120%22%20stroke%3D%22%23fff%22%20stroke-width%3D%222%22%20fill%3D%22none%22%2F%3E%3Cline%20x1%3D%220%22%20y1%3D%22120%22%20x2%3D%22300%22%20y2%3D%22120%22%20stroke%3D%22%23fff%22%20stroke-width%3D%221.5%22%2F%3E%3Ccircle%20cx%3D%22150%22%20cy%3D%22120%22%20r%3D%223%22%20fill%3D%22%23fff%22%2F%3E%3C%2Fsvg%3E");
  background-size: 100% 100%;
  background-repeat: no-repeat;
}

/* ===== 品牌 ===== */
.login-brand {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
  z-index: 1;
}

.brand-logo-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.brand-logo {
  width: 64rpx;
  height: 64rpx;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  line-height: 1.1;
}

.brand-subtitle {
  font-size: 22rpx;
  color: var(--blue-200);
  margin-top: 6rpx;
  letter-spacing: 1rpx;
  line-height: 1.4;
}

.login-brand {
  flex-direction: row;
  align-items: center;
  align-self: flex-start;
}

.brand-text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.login-brand .brand-name,
.login-brand .brand-subtitle { display: block; }

.login-brand .brand-logo-wrap { flex-shrink: 0; }

/* ===== Hero 大字报 ===== */
.login-hero {
  width: 100%;
  z-index: 1;
  margin-bottom: 56rpx;
}

.hero-tagline {
  font-size: 22rpx;
  color: var(--blue-200);
  letter-spacing: 6rpx;
  margin-bottom: 20rpx;
  font-weight: 600;
}

.hero-title, .hero-title-2 {
  font-weight: 900;
  line-height: 1;
  color: #fff;
  letter-spacing: -3rpx;
}

.hero-title {
  font-size: 140rpx;
  margin-bottom: 12rpx;
}

.hero-title-2 {
  font-size: 96rpx;
}

.hero-title .accent {
  color: var(--accent-orange);
  display: inline-block;
  margin-left: 8rpx;
}

.hero-sub {
  font-size: 24rpx;
  color: var(--blue-200);
  margin-top: 28rpx;
  line-height: 1.5;
  letter-spacing: 1rpx;
}

/* ===== 数据小卡 ===== */
.login-stats {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: var(--radius-lg);
  padding: 28rpx 16rpx;
  display: flex;
  align-items: center;
  z-index: 1;
  margin-bottom: 56rpx;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.ls-cell {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ls-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  letter-spacing: -1rpx;
  font-variant-numeric: tabular-nums;
}

.ls-num.accent { color: var(--accent-orange); }

.ls-unit {
  font-size: 22rpx;
  font-weight: 600;
  margin-left: 2rpx;
}

.ls-label {
  font-size: 20rpx;
  color: var(--blue-200);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

.ls-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.18);
}

/* ===== 登录区 ===== */
.login-actions {
  width: 100%;
  z-index: 1;
}

.login-btn {
  width: 100%;
  height: 104rpx;
  font-size: 32rpx;
  font-weight: 800;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  letter-spacing: 4rpx;
  padding: 0;
  line-height: 104rpx;
  text-align: center;
}

.login-btn::after { border: none; }
.login-btn:active { opacity: 0.92; transform: scale(0.99); }

.login-btn-content {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  height: 104rpx;
  line-height: 1;
}

.login-btn-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #fff;
  line-height: 1;
}

.wechat-icon {
  background-image: url("data:image/svg+xml;base64,");
}

.privacy-agreement {
  text-align: center;
  margin-top: 28rpx;
  padding: 8rpx 24rpx;
  font-size: 0;
}

.privacy-checkbox {
  display: inline-block;
  vertical-align: middle;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  background: transparent;
  margin-right: 12rpx;
  position: relative;
  top: 14rpx;
  box-sizing: border-box;
  transition: all 0.2s;
}

.privacy-checkbox.checked {
  background: var(--accent-orange);
  border-color: var(--accent-orange);
}

.privacy-check-mark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.privacy-text {
  display: inline-block;
  vertical-align: middle;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1.4;
}

.privacy-link {
  color: #fff;
  text-decoration: underline;
}

.login-footer {
  margin-top: auto;
  padding-top: 60rpx;
  z-index: 1;
}

.footer-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  letter-spacing: 1rpx;
  display: block;
}

.footer-disclaimer {
  font-size: 18rpx;
  color: rgba(255,255,255,0.32);
  line-height: 1.6;
  letter-spacing: 0.5rpx;
  display: block;
  margin-bottom: 16rpx;
  text-align: justify;
}

.footer-icp {
  font-size: 18rpx;
  color: rgba(255,255,255,0.32);
  letter-spacing: 1rpx;
  display: block;
  margin-top: 8rpx;
}
