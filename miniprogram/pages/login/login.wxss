.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, var(--blue-900) 0%, var(--blue-800) 35%, var(--blue-700) 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  padding: 120rpx 48rpx 60rpx;
  box-sizing: border-box;
}

.login-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.bg-glow {
  position: absolute;
  top: -120rpx;
  right: -160rpx;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.22) 0%, transparent 70%);
  border-radius: 50%;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  top: 80rpx;
  right: -80rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  bottom: 280rpx;
  left: -100rpx;
}

.circle-3 {
  width: 200rpx;
  height: 200rpx;
  bottom: -50rpx;
  right: 60rpx;
}

/* ===== 品牌 ===== */
.login-brand {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
  z-index: 1;
}

.brand-logo-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: rgba(255,255,255,0.1);
  border: 1rpx solid rgba(255,255,255,0.18);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.brand-logo {
  width: 64rpx;
  height: 64rpx;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  line-height: 1.1;
}

.brand-subtitle {
  font-size: 22rpx;
  color: var(--blue-200);
  margin-top: 6rpx;
  letter-spacing: 4rpx;
}

.login-brand {
  flex-direction: row;
  align-items: center;
  align-self: flex-start;
}

.login-brand .brand-name,
.login-brand .brand-subtitle { display: block; }

.login-brand .brand-logo-wrap { flex-shrink: 0; }

/* ===== Hero 大字报 ===== */
.login-hero {
  width: 100%;
  z-index: 1;
  margin-bottom: 56rpx;
}

.hero-tagline {
  font-size: 22rpx;
  color: var(--blue-200);
  letter-spacing: 6rpx;
  margin-bottom: 20rpx;
  font-weight: 600;
}

.hero-title, .hero-title-2 {
  font-weight: 900;
  line-height: 1;
  color: #fff;
  letter-spacing: -3rpx;
}

.hero-title {
  font-size: 140rpx;
  margin-bottom: 12rpx;
}

.hero-title-2 {
  font-size: 96rpx;
}

.hero-title .accent {
  color: var(--accent-orange);
  display: inline-block;
  margin-left: 8rpx;
}

.hero-sub {
  font-size: 24rpx;
  color: var(--blue-200);
  margin-top: 28rpx;
  line-height: 1.5;
  letter-spacing: 1rpx;
}

/* ===== 数据小卡 ===== */
.login-stats {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: var(--radius-lg);
  padding: 28rpx 16rpx;
  display: flex;
  align-items: center;
  z-index: 1;
  margin-bottom: 56rpx;
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}

.ls-cell {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ls-num {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1;
  letter-spacing: -1rpx;
  font-variant-numeric: tabular-nums;
}

.ls-num.accent { color: var(--accent-orange); }

.ls-unit {
  font-size: 22rpx;
  font-weight: 600;
  margin-left: 2rpx;
}

.ls-label {
  font-size: 20rpx;
  color: var(--blue-200);
  margin-top: 8rpx;
  letter-spacing: 1rpx;
}

.ls-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.18);
}

/* ===== 登录区 ===== */
.login-actions {
  width: 100%;
  z-index: 1;
}

.login-btn {
  width: 100%;
  height: 104rpx;
  font-size: 32rpx;
  font-weight: 800;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  color: #fff;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  letter-spacing: 4rpx;
  padding: 0;
  line-height: 104rpx;
  text-align: center;
}

.login-btn::after { border: none; }
.login-btn:active { opacity: 0.92; transform: scale(0.99); }

.login-btn-content {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  height: 104rpx;
  line-height: 1;
}

.login-btn-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.login-btn-text {
  font-size: 32rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
  color: #fff;
  line-height: 1;
}

.wechat-icon {
  background-image: url("data:image/svg+xml;base64,");
}

.privacy-agreement {
  text-align: center;
  margin-top: 28rpx;
  padding: 8rpx 24rpx;
  font-size: 0;
}

.privacy-checkbox {
  display: inline-block;
  vertical-align: middle;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  background: transparent;
  margin-right: 12rpx;
  position: relative;
  top: 14rpx;
  box-sizing: border-box;
  transition: all 0.2s;
}

.privacy-checkbox.checked {
  background: var(--accent-orange);
  border-color: var(--accent-orange);
}

.privacy-check-mark {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 22rpx;
  color: #fff;
  font-weight: bold;
  line-height: 1;
}

.privacy-text {
  display: inline-block;
  vertical-align: middle;
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
  line-height: 1.4;
}

.privacy-link {
  color: #fff;
  text-decoration: underline;
}

.login-footer {
  margin-top: auto;
  padding-top: 60rpx;
  z-index: 1;
}

.footer-text {
  font-size: 20rpx;
  color: rgba(255,255,255,0.4);
  letter-spacing: 1rpx;
  display: block;
}

.footer-disclaimer {
  font-size: 18rpx;
  color: rgba(255,255,255,0.32);
  line-height: 1.6;
  letter-spacing: 0.5rpx;
  display: block;
  margin-bottom: 16rpx;
  text-align: justify;
}

.footer-icp {
  font-size: 18rpx;
  color: rgba(255,255,255,0.32);
  letter-spacing: 1rpx;
  display: block;
  margin-top: 8rpx;
}
