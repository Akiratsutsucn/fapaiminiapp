<wxs module="m">
// WXML 表达式不支持调用 arr.indexOf() 等方法，故用 WXS 辅助判断多选选中态
module.exports.has = function (arr, val) {
  if (!arr) return false;
  return arr.indexOf(val) >= 0;
}
</wxs>

<view class="list-page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <view class="search-icon"></view>
      <input class="search-input" placeholder="搜索小区名、标题" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch" bindfocus="onSearchFocus" bindblur="onSearchBlur" confirm-type="search" />
      <view class="search-clear" wx:if="{{keyword}}" bindtap="onClearKeyword">
        <view class="search-clear-icon"></view>
      </view>
    </view>
    <!-- 搜索历史（聚焦且有历史时展示，最多 5 条） -->
    <view class="search-history" wx:if="{{showHistory && searchHistory.length > 0}}">
      <view class="sh-head">
        <text class="sh-title">搜索历史</text>
        <view class="sh-clear" bindtap="onClearHistory">清空</view>
      </view>
      <view class="sh-tags">
        <view class="sh-tag" wx:for="{{searchHistory}}" wx:key="*this" bindtap="onTapHistory" data-kw="{{item}}">{{item}}</view>
      </view>
    </view>
  </view>

  <!-- 入口标题（来自首页四按钮跳转：捡漏房源/即将开拍房源/昨日上架房源/昨日成交房源） -->
  <view class="preset-banner" wx:if="{{presetTitle}}">
    <text class="preset-title">{{presetTitle}}</text>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <view class="filter-item {{activeFilterPanel === 'district' ? 'active' : ''}}" bindtap="onTogglePanel" data-panel="district">
      <text>{{selectedDistrict || '区域'}}</text><view class="filter-arrow"></view>
    </view>
    <view class="filter-item {{activeFilterPanel === 'price' ? 'active' : ''}}" bindtap="onTogglePanel" data-panel="price">
      <text>{{priceLabel || '起拍价'}}</text><view class="filter-arrow"></view>
    </view>
    <view class="filter-item {{activeFilterPanel === 'more' ? 'active' : ''}}" bindtap="onTogglePanel" data-panel="more">
      <text>更多</text><view class="filter-arrow"></view>
    </view>
  </view>

  <!-- 排序栏 -->
  <view class="sort-bar">
    <view class="sort-item {{sortBy === 'default' ? 'active' : ''}}" bindtap="onSort" data-sort="default">默认排序</view>
    <view class="sort-item {{sortBy === 'starting_price' ? 'active' : ''}}" bindtap="onSort" data-sort="starting_price">
      起拍价<view class="sort-icon {{sortBy === 'starting_price' ? sortOrder : ''}}"></view>
    </view>
    <view class="sort-item {{sortBy === 'area' ? 'active' : ''}}" bindtap="onSort" data-sort="area">
      面积<view class="sort-icon {{sortBy === 'area' ? sortOrder : ''}}"></view>
    </view>
  </view>

  <!-- 筛选面板 -->
  <view class="filter-panel" wx:if="{{activeFilterPanel}}">
    <view class="panel-mask" bindtap="onClosePanel"></view>
    <view class="panel-content">
      <!-- 区域筛选 -->
      <view class="filter-options" wx:if="{{activeFilterPanel === 'district'}}">
        <view class="option-item {{!selectedDistrict ? 'selected' : ''}}" bindtap="onSelectDistrict" data-value="">全部区域</view>
        <view wx:for="{{districtOptions}}" wx:key="*this" class="option-item {{selectedDistrict === item ? 'selected' : ''}}" bindtap="onSelectDistrict" data-value="{{item}}">{{item}}</view>
      </view>
      <!-- 价格筛选 -->
      <view class="filter-options" wx:if="{{activeFilterPanel === 'price'}}">
        <view class="option-item {{!priceRange ? 'selected' : ''}}" bindtap="onSelectPriceRange" data-value="">不限</view>
        <view class="option-item {{priceRange === '0-1000000' ? 'selected' : ''}}" bindtap="onSelectPriceRange" data-value="0-1000000">100万以下</view>
        <view class="option-item {{priceRange === '1000000-3000000' ? 'selected' : ''}}" bindtap="onSelectPriceRange" data-value="1000000-3000000">100-300万</view>
        <view class="option-item {{priceRange === '3000000-5000000' ? 'selected' : ''}}" bindtap="onSelectPriceRange" data-value="3000000-5000000">300-500万</view>
        <view class="option-item {{priceRange === '5000000-' ? 'selected' : ''}}" bindtap="onSelectPriceRange" data-value="5000000-">500万以上</view>
      </view>
      <!-- 更多筛选（多选 + 确认） -->
      <view class="filter-more" wx:if="{{activeFilterPanel === 'more'}}">
        <view class="filter-group">
          <text class="filter-group-title">物业类型（可多选）</text>
          <view class="option-row">
            <view class="option-item multi {{pendingPropertyTypes.length === 0 ? 'selected' : ''}}" bindtap="onClearPropertyTypes">全部</view>
            <view class="option-item multi {{m.has(pendingPropertyTypes, '住宅') ? 'selected' : ''}}" bindtap="onTogglePropertyType" data-value="住宅">住宅</view>
            <view class="option-item multi {{m.has(pendingPropertyTypes, '商业') ? 'selected' : ''}}" bindtap="onTogglePropertyType" data-value="商业">商业</view>
            <view class="option-item multi {{m.has(pendingPropertyTypes, '工业') ? 'selected' : ''}}" bindtap="onTogglePropertyType" data-value="工业">工业</view>
            <view class="option-item multi {{m.has(pendingPropertyTypes, '办公') ? 'selected' : ''}}" bindtap="onTogglePropertyType" data-value="办公">办公</view>
          </view>
        </view>
        <view class="filter-group">
          <text class="filter-group-title">拍卖状态（可多选）</text>
          <view class="option-row">
            <view class="option-item multi {{m.has(pendingAuctionStatuses, '即将开拍') ? 'selected' : ''}}" bindtap="onToggleAuctionStatus" data-value="即将开拍">即将开拍</view>
            <view class="option-item multi {{m.has(pendingAuctionStatuses, '进行中') ? 'selected' : ''}}" bindtap="onToggleAuctionStatus" data-value="进行中">进行中</view>
          </view>
        </view>
        <view class="filter-group">
          <text class="filter-group-title">拍卖轮次（可多选）</text>
          <view class="option-row">
            <view class="option-item multi {{m.has(pendingAuctionRounds, '一拍') ? 'selected' : ''}}" bindtap="onToggleAuctionRound" data-value="一拍">一拍</view>
            <view class="option-item multi {{m.has(pendingAuctionRounds, '二拍') ? 'selected' : ''}}" bindtap="onToggleAuctionRound" data-value="二拍">二拍</view>
            <view class="option-item multi {{m.has(pendingAuctionRounds, '变卖') ? 'selected' : ''}}" bindtap="onToggleAuctionRound" data-value="变卖">变卖</view>
            <view class="option-item multi {{m.has(pendingAuctionRounds, '再次拍卖') ? 'selected' : ''}}" bindtap="onToggleAuctionRound" data-value="再次拍卖">再次拍卖</view>
          </view>
        </view>
        <view class="more-actions">
          <view class="btn-reset" bindtap="onResetMore">重置</view>
          <view class="btn-confirm" bindtap="onConfirmMore">确认</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 结果计数 -->
  <view class="result-count">共 {{total}} 套房源</view>

  <!-- 房源列表 -->
  <view wx:if="{{list.length > 0}}">
    <house-card wx:for="{{list}}" wx:key="id" property="{{item}}" />
  </view>
  <view class="empty-state" wx:else>
    <text>暂无符合条件的房源</text>
  </view>

  <!-- 加载更多 -->
  <view class="load-more" wx:if="{{hasMore}}">
    <text class="load-text" bindtap="onLoadMore">{{loading ? '加载中...' : '加载更多'}}</text>
  </view>

  <!-- 到底提示 -->
  <view class="list-bottom-line" wx:if="{{!hasMore && list.length > 0}}">
    <text>— 我是底线 —</text>
  </view>

  <!-- 浮动按钮：联系客服 + 回到顶部 -->
  <float-buttons bind:contact="onContact" bind:top="onScrollTop" />
</view>

