.list-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 80rpx;
}

/* ===== 搜索栏 ===== */
.search-bar {
  background: var(--bg-card);
  padding: 20rpx 24rpx;
  box-shadow: 0 1rpx 0 rgba(58, 90, 140, 0.06);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: var(--blue-50);
  border-radius: var(--radius-pill);
  padding: 14rpx 28rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--text-hint);
  border-radius: 50%;
}

.search-clear-icon {
  width: 20rpx;
  height: 20rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

/* ===== 筛选 / 排序栏 ===== */
.filter-bar {
  display: flex;
  background: var(--bg-card);
  border-bottom: 1rpx solid rgba(58, 90, 140, 0.06);
}

.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

.filter-item.active { color: var(--blue-900); }

.filter-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid var(--text-hint);
  margin-left: 8rpx;
  transition: transform 0.2s;
}

.filter-item.active .filter-arrow {
  border-top-color: var(--accent-orange);
  transform: rotate(180deg);
}

.sort-bar {
  display: flex;
  background: var(--bg-card);
  padding: 12rpx 16rpx;
  border-bottom: 1rpx solid rgba(58, 90, 140, 0.06);
  gap: 8rpx;
}

.sort-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 0;
  font-size: 24rpx;
  color: var(--blue-700);
  background: var(--blue-50);
  border-radius: var(--radius-pill);
  font-weight: 500;
}

.sort-item.active {
  color: #fff;
  background: var(--blue-900);
  font-weight: 700;
}

.sort-icon {
  width: 0;
  height: 0;
  margin-left: 4rpx;
}

.sort-icon.asc {
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-bottom: 8rpx solid currentColor;
}

.sort-icon.desc {
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 8rpx solid currentColor;
}

/* ===== 筛选面板 ===== */
.filter-panel { position: relative; }

.panel-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--bg-overlay);
  z-index: 50;
}

.panel-content {
  position: relative;
  z-index: 51;
  background: var(--bg-card);
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  box-shadow: var(--shadow-card);
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx;
  gap: 12rpx;
}

.option-item {
  padding: 12rpx 28rpx;
  background: var(--blue-50);
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--blue-700);
  font-weight: 500;
}

.option-item.selected {
  background: var(--blue-900);
  color: #fff;
  font-weight: 700;
}

.filter-group {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
}

.filter-group-title {
  font-size: 22rpx;
  color: var(--text-hint);
  letter-spacing: 1rpx;
  margin-bottom: 12rpx;
  display: block;
}

.option-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* ===== 结果计数 ===== */
.result-count {
  padding: 20rpx 28rpx;
  font-size: 22rpx;
  color: var(--text-hint);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.result-count::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 22rpx;
  background: var(--accent-orange);
  border-radius: 3rpx;
}

/* ===== 加载更多 ===== */
.load-more {
  text-align: center;
  padding: 32rpx;
}

.load-text {
  font-size: 24rpx;
  color: var(--blue-600);
  padding: 12rpx 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-pill);
  display: inline-block;
  box-shadow: var(--shadow-card);
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: var(--text-hint);
  font-size: 26rpx;
}

/* ===== 入口标题（捡漏房源/即将开拍房源/昨日上架房源/昨日成交房源） ===== */
.preset-banner {
  display: flex;
  align-items: center;
  background: var(--bg-card);
  padding: 18rpx 28rpx;
  border-bottom: 1rpx solid rgba(58, 90, 140, 0.06);
}

.preset-banner::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 28rpx;
  background: var(--accent-orange);
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.preset-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--blue-900);
  letter-spacing: 1rpx;
}

/* ===== 「更多」面板：多选 + 确认 ===== */
.filter-more {
  padding: 24rpx 0 16rpx;
}

.option-item.multi {
  /* 多选样式：与单选区分（边框感更强） */
  border: 1rpx solid var(--blue-50);
}

.option-item.multi.selected {
  background: var(--blue-900);
  color: #fff;
  border-color: var(--blue-900);
}

.more-actions {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx 8rpx;
  border-top: 1rpx solid rgba(58, 90, 140, 0.06);
}

.btn-reset, .btn-confirm {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: var(--radius-pill);
}

.btn-reset {
  background: var(--blue-50);
  color: var(--blue-700);
}

.btn-confirm {
  background: var(--blue-900);
  color: #fff;
  box-shadow: var(--shadow-card);
}
