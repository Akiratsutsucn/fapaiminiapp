<view class="cs-page">
  <view class="cs-header">
    <view class="cs-icon-wrap">
      <view class="cs-icon"></view>
    </view>
    <text class="cs-title">需要帮助？</text>
    <text class="cs-desc">{{serviceText}}</text>
  </view>

  <view class="cs-options">
    <view class="cs-card" bindtap="onCallPhone">
      <view class="cs-card-left">
        <view class="card-icon phone-icon"></view>
        <view class="cs-card-text">
          <text class="cs-card-title">客服电话</text>
          <text class="cs-card-sub">{{phoneNumber}}</text>
        </view>
      </view>
      <view class="cs-card-arrow"></view>
    </view>
  </view>

  <view class="cs-divider">
    <view class="divider-line"></view>
    <text class="divider-text">或给客服留言</text>
    <view class="divider-line"></view>
  </view>

  <view class="cs-form">
    <view class="form-group">
      <text class="form-label">姓名 <text class="required">*</text></text>
      <input class="form-input" placeholder="请输入您的姓名" value="{{form.name}}" bindinput="onInput" data-field="name" maxlength="32" />
    </view>
    <view class="form-group">
      <text class="form-label">手机号 <text class="required">*</text></text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入 11 位手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" />
    </view>
    <view class="form-group">
      <text class="form-label">留言内容 <text class="required">*</text></text>
      <textarea class="form-textarea" placeholder="请描述您的问题或购房需求，客服将尽快与您联系" value="{{form.remark}}" bindinput="onInput" data-field="remark" maxlength="500" auto-height />
      <text class="form-tip">{{form.remark.length}} / 500</text>
    </view>
    <button class="cs-submit-btn btn-primary" bindtap="onSubmitMessage" loading="{{submitting}}">提交留言</button>
  </view>
</view>
