.cs-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding-bottom: 60rpx;
}

/* ===== Hero 头部 ===== */
.cs-header {
  background: linear-gradient(135deg, var(--blue-900) 0%, var(--blue-700) 100%);
  color: #fff;
  padding: 60rpx 32rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.cs-header::after {
  content: '';
  position: absolute;
  right: -80rpx;
  top: -80rpx;
  width: 360rpx;
  height: 360rpx;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.18) 0%, transparent 70%);
  border-radius: 50%;
}

.cs-icon-wrap {
  width: 110rpx;
  height: 110rpx;
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.cs-icon {
  width: 56rpx;
  height: 56rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  border: none;
}

.cs-icon::after { display: none; }

.cs-title {
  display: block;
  font-size: 56rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
  line-height: 1.1;
  margin-bottom: 12rpx;
  color: #fff;
  position: relative;
  z-index: 1;
}

.cs-desc {
  display: block;
  font-size: 24rpx;
  color: var(--blue-200);
  letter-spacing: 1rpx;
  position: relative;
  z-index: 1;
}

/* ===== 客服卡片（电话）— 上浮叠加在 hero ===== */
.cs-options {
  margin: -50rpx 24rpx 0;
  position: relative;
  z-index: 2;
}

.cs-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-elevated);
}

.cs-card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.phone-icon {
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  border: none;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 53, 0.3);
}

.phone-icon::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 36rpx;
  height: 36rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  border: none;
  border-radius: 0;
}

.cs-card-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.cs-card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--blue-900);
}

.cs-card-sub {
  font-size: 32rpx;
  color: var(--accent-orange-text);
  font-weight: 800;
  font-variant-numeric: tabular-nums;
  letter-spacing: 1rpx;
}

.cs-card-arrow {
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 14rpx solid var(--blue-600);
}

/* ===== 分隔 ===== */
.cs-divider {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 40rpx 24rpx 24rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(90deg, transparent, var(--blue-200), transparent);
}

.divider-text {
  font-size: 22rpx;
  color: var(--text-hint);
  letter-spacing: 2rpx;
  font-weight: 600;
}

/* ===== 表单 ===== */
.cs-form {
  margin: 0 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: 32rpx 28rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: var(--blue-700);
  margin-bottom: 12rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.required {
  color: var(--accent-orange-text);
  margin-left: 4rpx;
  font-weight: 800;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
  background: var(--blue-50);
  color: var(--blue-900);
  transition: all 0.2s;
}

.form-input:focus {
  border-color: var(--accent-orange);
  background: #fff;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid transparent;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  box-sizing: border-box;
  background: var(--blue-50);
  color: var(--blue-900);
  line-height: 1.6;
}

.form-textarea:focus {
  border-color: var(--accent-orange);
  background: #fff;
}

.form-tip {
  display: block;
  text-align: right;
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
  font-variant-numeric: tabular-nums;
}

.cs-submit-btn {
  width: 100%;
  margin-top: 12rpx;
  height: 96rpx;
  font-size: 30rpx;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  color: #fff;
  border: none;
  border-radius: var(--radius-pill);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
  letter-spacing: 4rpx;
}

.cs-submit-btn::after {
  border: none;
}

.cs-cancel {
  width: 400rpx;
  margin: 32rpx auto 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  height: 80rpx;
  line-height: 1;
  padding: 0;
  font-size: 26rpx;
  color: var(--blue-700);
  background: transparent;
  border: 2rpx solid var(--blue-200);
  border-radius: var(--radius-pill);
  font-weight: 600;
}

.cs-cancel::after {
  border: none;
}
