.detail-page {
  padding-bottom: 200rpx;
  background: var(--bg-page);
  min-height: 100vh;
}

.detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx 0;
}

.favorite-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border-radius: 50%;
  box-shadow: var(--shadow-card);
}

.fav-icon {
  width: 40rpx;
  height: 40rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  transition: opacity 0.15s;
}

.favorite-btn.active .fav-icon {
  background-image: url("data:image/svg+xml;base64,");
}

.detail-header .tag {
  padding: 8rpx 20rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.detail-title-section {
  padding: 24rpx 24rpx 16rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--blue-900);
  line-height: 1.35;
  letter-spacing: -1rpx;
}

.detail-location {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.loc-icon {
  width: 24rpx;
  height: 24rpx;
  border: 2rpx solid var(--accent-orange);
  border-radius: 50%;
  margin-right: 8rpx;
  position: relative;
}

.loc-icon::after {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  background: var(--accent-orange);
  border-radius: 50%;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
}

/* ===== 风险/利好标签（红黄绿） ===== */
.risk-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 0 24rpx 8rpx;
}

.risk-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.3;
}

.risk-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.risk-danger {
  background: rgba(184, 90, 90, 0.12);
  color: var(--danger);
}
.risk-danger .risk-dot { background: var(--danger); }

.risk-warning {
  background: rgba(196, 147, 90, 0.14);
  color: var(--accent-gold-text);
}
.risk-warning .risk-dot { background: var(--warning); }

.risk-safe {
  background: rgba(74, 140, 122, 0.12);
  color: var(--success);
}
.risk-safe .risk-dot { background: var(--success); }

/* ===== 价格大字报区 ===== */
.price-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 12rpx;
  background: linear-gradient(135deg, var(--blue-50), #fff);
  padding: 24rpx 20rpx;
  margin: 0 24rpx;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  border-top: 4rpx solid var(--accent-orange);
}

.price-item {
  text-align: center;
  position: relative;
}

.price-item + .price-item::before {
  content: '';
  position: absolute;
  left: -6rpx;
  top: 16%;
  height: 68%;
  width: 1rpx;
  background: rgba(58, 90, 140, 0.1);
}

.price-value {
  display: block;
  font-size: 44rpx;
  font-weight: 900;
  color: var(--blue-900);
  letter-spacing: -1rpx;
  line-height: 1.05;
  font-variant-numeric: tabular-nums;
}

.price-value.primary { color: var(--blue-900); }
.price-value.accent  { color: var(--accent-orange-text); }

.price-label {
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 8rpx;
}

/* ===== 倒计时盒 ===== */
.auction-time-box {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, var(--accent-orange-soft), #fff);
  border-radius: var(--radius-md);
  border-left: 8rpx solid var(--accent-orange);
}

.time-countdown {
  font-size: 38rpx;
  font-weight: 800;
  color: var(--accent-orange-text);
  letter-spacing: -0.5rpx;
}

.time-label {
  font-size: 24rpx;
  color: var(--accent-orange-text);
  margin-left: 4rpx;
  font-weight: 600;
}

.time-right {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ===== Tab 栏 ===== */
.tab-bar {
  display: flex;
  background: var(--bg-card);
  margin: 24rpx 24rpx 0;
  border-radius: var(--radius-md);
  padding: 8rpx;
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  font-weight: 600;
  transition: all 0.2s;
}

.tab-item.active {
  color: #fff;
  background: var(--blue-900);
}

.tab-item.active::after { display: none; }

.tab-content {
  padding: 16rpx 24rpx 24rpx;
}

/* ===== 信息表格 ===== */
.info-grid {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
  padding: 8rpx 24rpx;
  box-shadow: var(--shadow-card);
}

.info-row {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(58, 90, 140, 0.06);
}

.info-row:last-child { border-bottom: none; }

.info-k {
  width: 160rpx;
  font-size: 24rpx;
  color: var(--text-hint);
  flex-shrink: 0;
}

.info-v {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* 详细地址：放宽字距，避免挤在一起；每行最多 16 个汉字(32 字节)，超出自动换行 */
.info-v-address {
  letter-spacing: 2rpx;
  line-height: 1.6;
  word-break: break-all;
  white-space: normal;
  max-width: 16em;
}

/* ===== 段落标题 ===== */
.section-title {
  font-size: 28rpx;
  font-weight: 800;
  color: var(--blue-900);
  margin-bottom: 16rpx;
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 24rpx;
  background: var(--accent-orange);
  border-radius: 3rpx;
}

.community-info {
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: 8rpx 24rpx 16rpx;
  box-shadow: var(--shadow-card);
}

/* ===== 小区详情卡 V2（贝壳数据） ===== */
.community-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx 24rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
}

.cc-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(58, 90, 140, 0.08);
}

.cc-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--blue-900);
  letter-spacing: -0.5rpx;
}

.cc-source {
  font-size: 20rpx;
  color: var(--text-hint);
  letter-spacing: 1rpx;
}

.cc-desc {
  font-size: 26rpx;
  color: var(--text-primary);
  line-height: 1.8;
  text-indent: 2em;
  background: var(--blue-50);
  border-left: 6rpx solid var(--accent-orange);
  padding: 18rpx 20rpx;
  border-radius: var(--radius-sm);
  margin-bottom: 24rpx;
}

.cc-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.cc-cell {
  background: linear-gradient(135deg, var(--blue-50), #fff);
  border-radius: var(--radius-md);
  padding: 18rpx 16rpx;
  text-align: center;
  position: relative;
}

.cc-cell:nth-child(1) {
  background: linear-gradient(135deg, var(--accent-orange-soft), #fff);
}

.cc-num {
  display: block;
  font-size: 38rpx;
  font-weight: 800;
  color: var(--blue-900);
  letter-spacing: -1rpx;
  font-variant-numeric: tabular-nums;
  line-height: 1.1;
}

.cc-num.accent { color: var(--accent-orange-text); }

.cc-label {
  display: block;
  font-size: 20rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
}

.cc-info-list .info-row {
  display: flex;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(58, 90, 140, 0.05);
  font-size: 25rpx;
}

.cc-info-list .info-row:last-child { border-bottom: none; }
.cc-info-list .info-k { width: 140rpx; color: var(--text-hint); flex-shrink: 0; }
.cc-info-list .info-v { flex: 1; color: var(--text-primary); font-weight: 500; }

/* 价差分析 */
.cc-bargain {
  margin-top: 20rpx;
  padding: 20rpx;
  background: linear-gradient(135deg, var(--blue-900), var(--blue-700));
  border-radius: var(--radius-md);
  color: #fff;
  position: relative;
  overflow: hidden;
}

.cc-bargain::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.18) 0%, transparent 70%);
  border-radius: 50%;
}

.cc-bargain-title {
  font-size: 26rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
  position: relative;
  z-index: 1;
}

.cc-bargain-row {
  display: flex;
  justify-content: space-around;
  position: relative;
  z-index: 1;
}

.cb-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.cb-label {
  font-size: 20rpx;
  color: var(--blue-200);
}

.cb-value {
  font-size: 30rpx;
  font-weight: 800;
  color: #fff;
  font-variant-numeric: tabular-nums;
  letter-spacing: -0.5rpx;
}

.cb-value.accent { color: var(--accent-orange-text); }

.cc-bargain-saving {
  margin-top: 16rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--blue-200);
  position: relative;
  z-index: 1;
}

.cc-bargain-saving .accent {
  color: var(--accent-orange-text);
  font-weight: 800;
  font-size: 26rpx;
}

.price-highlight {
  color: var(--accent-orange-text) !important;
  font-weight: 700;
}

.price-green {
  color: var(--accent-orange-text) !important;
  font-weight: 700;
}

/* 独家解读卡片（袋鼠风格） */
.commentary-card {
  margin-top: var(--spacing-lg);
  background: linear-gradient(135deg, #FFF7E8 0%, #FFEED1 100%);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  border: 2rpx solid #F5D38A;
}
.commentary-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}
.commentary-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #C29A4B;
  background-image: url("data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHZpZXdCb3g9IjAgMCAyNCAyNCIgZmlsbD0iI2ZmZiI+PHBhdGggZD0iTTEyIDJsMi45IDYuMjZMMjIgOS4yN2wtNSA0Ljg3TDE4LjE4IDIyIDEyIDE4LjU2IDUuODIgMjIgNyAxNC4xNGwtNS00Ljg3IDcuMS0xLjAxeiIvPjwvc3ZnPg==");
  background-repeat: no-repeat;
  background-position: center;
  background-size: 28rpx 28rpx;
  margin-right: var(--spacing-xs);
}
.commentary-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: #6B4F1D;
}
.commentary-section {
  display: flex;
  margin-top: var(--spacing-sm);
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid rgba(194, 154, 75, 0.25);
}
.commentary-section:first-child {
  margin-top: 0;
  padding-top: 0;
  border-top: none;
}
.commentary-label {
  flex-shrink: 0;
  width: 130rpx;
  font-size: var(--font-sm);
  color: #6B4F1D;
  font-weight: 600;
  line-height: 1.7;
}
.commentary-text {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.7;
}

/* 公告全文区 */
.notice-section {
  margin-top: var(--spacing-lg);
}
.notice-text {
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
  background: var(--bg-card);
  padding: var(--spacing-md);
  border-radius: var(--radius-sm);
}
.notice-text.collapsed {
  max-height: 360rpx;
  overflow: hidden;
  position: relative;
}
.notice-text.collapsed::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 80rpx;
  background: linear-gradient(180deg, rgba(255,255,255,0) 0%, var(--bg-card) 90%);
}
.notice-toggle {
  margin-top: var(--spacing-xs);
  text-align: center;
  font-size: var(--font-sm);
  color: var(--blue-500);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
}
.toggle-arrow {
  font-size: 22rpx;
  margin-left: 4rpx;
}

/* 板块介绍 */
.block-intro {
  margin-top: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
}
.block-intro-text {
  font-size: var(--font-sm);
  color: var(--text-primary);
  line-height: 1.8;
  text-indent: 2em;
}

/* 房源位置地图 */
.map-section {
  margin-top: var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
}
.map-canvas {
  width: 100%;
  height: 400rpx;
  border-radius: var(--radius-sm);
  margin-top: var(--spacing-sm);
}
.map-wrap {
  position: relative;
  margin-top: var(--spacing-sm);
}
.map-wrap .map-canvas {
  margin-top: 0;
  pointer-events: none;
}
.map-zoom-hint {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 22rpx;
  border-radius: var(--radius-pill);
  pointer-events: none;
}
.map-zoom-icon {
  font-size: 24rpx;
  line-height: 1;
}

/* 板块分析浮层 */
.analysis-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.analysis-modal {
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  width: 100%;
  max-height: 70vh;
  overflow-y: auto;
  padding-bottom: env(safe-area-inset-bottom);
}

.analysis-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.analysis-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.analysis-close {
  font-size: 44rpx;
  color: #999;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.analysis-body {
  padding: 24rpx 36rpx 48rpx;
}

.analysis-stats {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 32rpx;
}

.stat-item {
  width: 50%;
  padding: 20rpx 0;
  display: flex;
  flex-direction: column;
}

.stat-val {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a2f52;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.analysis-section {
  margin-bottom: 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.as-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.as-text {
  font-size: 28rpx;
  color: #666;
}

.as-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.as-tag {
  display: inline-block;
  background: #f5f6f8;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #555;
}

.analysis-loading {
  padding: 80rpx;
  text-align: center;
  color: #999;
}

/* 周边配套 */
.amenity-category {
  margin-bottom: 28rpx;
}

.amenity-cat-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a2f52;
  margin-bottom: 12rpx;
  padding-left: 8rpx;
  border-left: 6rpx solid #1a2f52;
}

.amenity-list {
  background: #fafbfc;
  border-radius: 12rpx;
  overflow: hidden;
}

.amenity-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.amenity-item:last-child {
  border-bottom: none;
}

.amenity-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  overflow: hidden;
}

.amenity-name {
  font-size: 28rpx;
  color: #333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.amenity-addr {
  font-size: 22rpx;
  color: #999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.amenity-dist {
  font-size: 24rpx;
  color: #1a2f52;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 16rpx;
}
