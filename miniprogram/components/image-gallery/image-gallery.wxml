<view class="gallery">
  <swiper class="swiper" indicator-dots="{{images.length > 1}}" indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#ffffff" autoplay="{{autoplay}}" interval="4000" duration="400" circular>
    <swiper-item wx:for="{{images}}" wx:key="id">
      <image class="swiper-image" src="{{item.image_url}}" mode="aspectFill" lazy-load binderror="onImageError" data-index="{{index}}" />
    </swiper-item>
  </swiper>
  <view class="gallery-counter" wx:if="{{images.length > 1}}">{{current + 1}}/{{images.length}}</view>
</view>
