.banner-wrap {
  margin: 0 24rpx;
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-card);
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx 36rpx;
  background: linear-gradient(transparent, rgba(26, 47, 82, 0.85));
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}
