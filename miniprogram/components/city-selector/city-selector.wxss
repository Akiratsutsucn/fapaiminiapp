.city-selector {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-sm);
}

.city-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.city-pin {
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid var(--accent-orange);
  border-radius: 50%;
  position: relative;
  background: var(--accent-orange);
  box-shadow: 0 0 0 3rpx rgba(255, 107, 53, 0.3);
}

.city-pin::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  border-top: 8rpx solid var(--accent-orange);
}

.city-name {
  color: #fff;
  font-size: var(--font-md);
  font-weight: 500;
  margin-right: 6rpx;
}

.city-arrow {
  width: 0;
  height: 0;
  border-left: 8rpx solid transparent;
  border-right: 8rpx solid transparent;
  border-top: 10rpx solid rgba(255,255,255,0.7);
}

.city-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-overlay);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.3s, visibility 0.3s;
}

.city-overlay.show {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
}

.city-panel {
  position: absolute;
  top: 200rpx;
  left: var(--spacing-md);
  right: var(--spacing-md);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  border-bottom: 1rpx solid var(--border-color);
}

.panel-title {
  font-size: var(--font-lg);
  font-weight: 600;
}

.panel-close {
  width: 40rpx;
  height: 40rpx;
  position: relative;
}

.panel-close::before,
.panel-close::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 24rpx;
  height: 2rpx;
  background: var(--text-secondary);
}

.panel-close::before { transform: translate(-50%, -50%) rotate(45deg); }
.panel-close::after { transform: translate(-50%, -50%) rotate(-45deg); }

.city-list {
  padding: var(--spacing-sm);
}

.city-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  font-size: var(--font-md);
  border-radius: var(--radius-sm);
}

.city-item.active {
  background: var(--blue-100);
  color: var(--blue-700);
  font-weight: 500;
}

.city-check {
  width: 24rpx;
  height: 14rpx;
  border-left: 3rpx solid var(--blue-600);
  border-bottom: 3rpx solid var(--blue-600);
  transform: rotate(-45deg);
}
