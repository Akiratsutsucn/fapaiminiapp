.house-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin: 12rpx 24rpx;
  overflow: hidden;
}

.house-card:active { transform: scale(0.99); }

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 380rpx;
  background: var(--blue-100);
}

.card-image { width: 100%; height: 100%; }

.card-tag-v2 {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: var(--radius-pill);
  color: #fff;
  z-index: 2;
  background: rgba(26, 47, 82, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  letter-spacing: 1rpx;
}

.card-tag-v2.tag-blue   { background: rgba(58, 90, 140, 0.85); }
.card-tag-v2.tag-orange { background: rgba(255, 107, 53, 0.85); }
.card-tag-v2.tag-red    { background: rgba(184, 90, 90, 0.85); }
.card-tag-v2.tag-green  { background: rgba(74, 140, 122, 0.85); }

.card-discount-corner {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  color: #fff;
  padding: 16rpx 26rpx;
  border-radius: var(--radius-md);
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.55);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
  transform: rotate(15deg);
  transform-origin: center;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  letter-spacing: 1rpx;
  min-width: 120rpx;
}

.dc-discount {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -1rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.18);
}

.dc-saving {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.45);
  letter-spacing: 1rpx;
  white-space: nowrap;
}

/* 超人气角标：拍卖价不低于评估价时替代橙色折扣率，用红色人气色 */
.card-hot-corner {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: linear-gradient(135deg, #f5365c 0%, #f56036 100%);
  color: #fff;
  padding: 16rpx 26rpx;
  border-radius: var(--radius-md);
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(245, 54, 92, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  transform: rotate(15deg);
  transform-origin: center;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  letter-spacing: 1rpx;
  min-width: 120rpx;
}

.hc-text {
  font-size: 32rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.18);
}

.card-body { padding: 20rpx 24rpx; }

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--blue-900);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
  letter-spacing: -0.5rpx;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.card-price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed rgba(58, 90, 140, 0.15);
}

.price-main {
  display: flex;
  align-items: baseline;
}

.price-value {
  font-size: 56rpx;
  font-weight: 900;
  color: var(--blue-900);
  letter-spacing: -2rpx;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.price-unit {
  font-size: 22rpx;
  color: var(--blue-700);
  margin-left: 4rpx;
  font-weight: 600;
}

.price-sub {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.sub-label {
  font-size: 20rpx;
  color: var(--text-hint);
}

.sub-value {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-secondary);
  text-decoration: line-through;
}

.card-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(58, 90, 140, 0.05);
}

.time-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent-orange);
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.2);
}

.time-label {
  font-size: 20rpx;
  color: var(--text-hint);
}

.time-value {
  font-size: 22rpx;
  color: var(--blue-700);
  font-weight: 600;
}
