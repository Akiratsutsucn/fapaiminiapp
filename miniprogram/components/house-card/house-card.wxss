.house-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin: 12rpx 24rpx;
  overflow: hidden;
}

.house-card:active { transform: scale(0.99); }

.card-image-wrap {
  position: relative;
  width: 100%;
  height: 380rpx;
  background: var(--blue-100);
}

.card-image { width: 100%; height: 100%; }

.card-tag-v2 {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  padding: 10rpx 22rpx;
  font-size: 28rpx;
  font-weight: 700;
  border-radius: var(--radius-pill);
  color: #fff;
  z-index: 2;
  background: rgba(26, 47, 82, 0.7);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  letter-spacing: 2rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.25);
}

.card-tag-v2.tag-blue   { background: rgba(58, 90, 140, 0.85); }
.card-tag-v2.tag-orange { background: rgba(255, 107, 53, 0.85); }
.card-tag-v2.tag-red    { background: rgba(184, 90, 90, 0.85); }
.card-tag-v2.tag-green  { background: rgba(74, 140, 122, 0.85); }

.card-discount-corner {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  color: #fff;
  padding: 16rpx 26rpx;
  border-radius: var(--radius-md);
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.55);
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 2;
  transform: rotate(15deg);
  transform-origin: center;
  border: 2rpx solid rgba(255, 255, 255, 0.4);
  letter-spacing: 1rpx;
  min-width: 120rpx;
}

.dc-discount {
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -1rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.18);
}

.dc-saving {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.45);
  letter-spacing: 1rpx;
  white-space: nowrap;
}

.card-body { padding: 20rpx 24rpx; }

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--blue-900);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
  letter-spacing: 1.5rpx;
}

.card-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.card-price-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx dashed rgba(58, 90, 140, 0.15);
}

.price-main {
  display: flex;
  align-items: baseline;
}

.price-value {
  font-size: 56rpx;
  font-weight: 900;
  color: var(--blue-900);
  letter-spacing: -2rpx;
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.price-unit {
  font-size: 22rpx;
  color: var(--blue-700);
  margin-left: 4rpx;
  font-weight: 600;
}

.price-sub {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  flex: 1;
  gap: 8rpx;
}

.sub-label {
  font-size: 20rpx;
  color: var(--text-hint);
}

.sub-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
}

/* 平台来源标签：浅色描边小标签，三色区分阿里/京东/公拍。
   位于价格行末尾，与 .price-sub 的 flex:1 自然推到最右边。 */
.platform-tag {
  flex-shrink: 0;
  align-self: center;
  font-size: 20rpx;
  line-height: 1.2;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  border: 1rpx solid currentColor;
  background: transparent;
  letter-spacing: 0;
  white-space: nowrap;
}
.platform-tag:active {
  opacity: 0.6;
}

.platform-jd {
  color: #E1251B;
}

.platform-ali {
  color: #FF6A00;
}

.platform-gpai {
  color: #3D5C7C;
}

.card-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(58, 90, 140, 0.05);
}

.time-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--accent-orange);
  box-shadow: 0 0 0 4rpx rgba(255, 107, 53, 0.2);
}

.time-label {
  font-size: 20rpx;
  color: var(--text-hint);
}

.time-value {
  font-size: 22rpx;
  color: var(--blue-700);
  font-weight: 600;
}

/* 联系方式门禁弹窗 */
.hc-contact-mask {
  position: fixed;
  left: 0; top: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}
.hc-contact-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 40rpx;
  box-sizing: border-box;
}
.hc-contact-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
}
.hc-contact-tip {
  font-size: 26rpx;
  color: #8a8a8a;
  margin-top: 16rpx;
  margin-bottom: 32rpx;
  line-height: 1.5;
  text-align: center;
}
.hc-contact-field {
  margin-bottom: 28rpx;
}
.hc-contact-label {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}
.hc-contact-req {
  color: #ff4d4f;
}
.hc-contact-input {
  width: 100%;
  height: 84rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 30rpx;
}
.hc-contact-btns {
  display: flex;
  gap: 24rpx;
  margin-top: 40rpx;
}
.hc-contact-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  text-align: center;
  padding: 0;
}
.hc-contact-btn-cancel {
  background: #f0f0f0;
  color: #666;
}
.hc-contact-btn-ok {
  background: #ff6b35;
  color: #fff;
}
.hc-contact-btn-ok::after,
.hc-contact-btn-cancel::after {
  border: none;
}

/* 商圈板块标签(数据来源贝壳找房,渐变胶囊+CSS定位图标) */
.biz-tag {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 12rpx 4rpx 10rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border: 1rpx solid rgba(255, 138, 0, 0.25);
  max-width: 220rpx;
}
/* 纯 CSS 定位图标:水滴形(顶圆底尖)+ 内部空心圆,不用 emoji */
.biz-tag-pin {
  position: relative;
  width: 14rpx;
  height: 14rpx;
  background: #E65100;
  border-radius: 50% 50% 50% 0;
  transform: rotate(-45deg);
  flex-shrink: 0;
}
.biz-tag-pin::after {
  content: '';
  position: absolute;
  top: 3rpx;
  left: 3rpx;
  width: 6rpx;
  height: 6rpx;
  background: #FFF3E0;
  border-radius: 50%;
}
.biz-tag-text {
  font-size: 20rpx;
  line-height: 1.2;
  color: #E65100;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
