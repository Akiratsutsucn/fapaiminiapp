<view class="house-card" bindtap="onTap">
  <view class="card-image-wrap">
    <image class="card-image" src="{{coverImage}}" mode="aspectFill" lazy-load />
    <view class="card-tag-v2 {{statusTagClass}}">{{statusLabel}}</view>
    <view class="card-discount-corner" wx:if="{{discount || savingWan}}">
      <text class="dc-discount" wx:if="{{discount}}">{{discount}}</text>
      <text class="dc-saving" wx:if="{{savingWan}}">立省 {{savingWan}} 万</text>
    </view>
  </view>
  <view class="card-body">
    <view class="card-title">{{title}}</view>
    <view class="card-meta">
      <text class="meta-tag" wx:if="{{district}}">{{district}}</text>
      <text class="meta-tag" wx:if="{{auctionRound}}">{{auctionRound}}</text>
      <text class="meta-tag" wx:if="{{area}}">{{area}}㎡</text>
      <text class="meta-tag" wx:if="{{propertyType}}" style="background:#EAF2FC;color:#2D4A7A;border:1rpx solid #BBD3EF;font-weight:600;">{{propertyType}}</text>
      <view class="biz-tag" wx:if="{{subDistrict}}" style="display:inline-flex;align-items:center;gap:5rpx;padding:4rpx 14rpx 4rpx 10rpx;border-radius:8rpx;background:#FDF1E7;border:1rpx solid #F2D2B6;max-width:220rpx;">
        <view class="biz-tag-pin"></view>
        <text class="biz-tag-text" style="color:#C8410D;font-size:22rpx;line-height:1.4;font-weight:500;">{{subDistrict}}</text>
      </view>
      <text class="meta-tag" wx:if="{{layout}}">{{layout}}</text>
    </view>
    <view class="card-price-row">
      <view class="price-main">
        <text class="price-value">{{startingPriceWan}}</text>
        <text class="price-unit">{{startingUnit}}</text>
      </view>
      <view class="price-sub" wx:if="{{appraisalPriceWan}}">
        <text class="sub-label">评估价</text>
        <text class="sub-value">{{appraisalPriceWan}} 万</text>
      </view>
      <view class="platform-tag platform-{{platformKey}}" wx:if="{{platformKey}}" catchtap="onTapPlatform">{{platformLabel}}</view>
    </view>
    <view class="card-time" wx:if="{{auctionTime}}">
      <view class="time-dot"></view>
      <text class="time-label">开拍</text>
      <text class="time-value">{{auctionTime}}</text>
    </view>
  </view>

  <!-- 联系方式门禁弹窗:未填手机号+姓氏时,点击平台标记先要求填写 -->
  <view class="hc-contact-mask" wx:if="{{showContactModal}}" catchtap="onCloseContactModal">
    <view class="hc-contact-modal" catchtap="noop">
      <view class="hc-contact-title">填写联系方式</view>
      <view class="hc-contact-tip">查看房源在拍卖平台的链接,请先留下联系方式,方便顾问为您 1 对 1 服务</view>
      <view class="hc-contact-field">
        <text class="hc-contact-label">姓氏 <text class="hc-contact-req">*</text></text>
        <input class="hc-contact-input" placeholder="请输入您的姓氏(如:张)" maxlength="10" value="{{contactForm.surname}}" bindinput="onContactInput" data-field="surname" />
      </view>
      <view class="hc-contact-field">
        <text class="hc-contact-label">手机号 <text class="hc-contact-req">*</text></text>
        <input class="hc-contact-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{contactForm.phone}}" bindinput="onContactInput" data-field="phone" />
      </view>
      <view class="hc-contact-btns">
        <button class="hc-contact-btn hc-contact-btn-cancel" catchtap="onCloseContactModal">取消</button>
        <button class="hc-contact-btn hc-contact-btn-ok" loading="{{savingContact}}" catchtap="onSubmitContact">确定</button>
      </view>
    </view>
  </view>
</view>
