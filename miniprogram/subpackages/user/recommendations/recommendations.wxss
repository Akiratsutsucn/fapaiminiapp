.rec-page {
  min-height: 100vh;
  background: var(--bg-page);
  padding: 16rpx 0 40rpx;
}

.rec-block {
  margin-bottom: 8rpx;
}

.rec-reason {
  position: relative;
  margin: 16rpx 24rpx 0;
  padding: 22rpx 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md) var(--radius-md) 0 0;
  box-shadow: var(--shadow-card);
}

.rec-reason-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.rec-badge {
  display: inline-block;
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--accent-gold) 0%, #E8C078 100%);
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  letter-spacing: 1rpx;
}

.rec-unread {
  font-size: 20rpx;
  color: var(--accent-orange-text);
  font-weight: 600;
}

.rec-reason-text {
  font-size: 26rpx;
  color: var(--blue-900);
  line-height: 1.6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
  color: var(--text-hint);
}

.empty-state text {
  font-size: 28rpx;
}

.empty-sub {
  font-size: 24rpx !important;
  color: var(--text-disabled);
  margin-top: 16rpx;
  text-align: center;
  line-height: 1.6;
}
