<view class="form-page">
  <!-- 服务介绍区 -->
  <view class="service-intro">
    <view class="intro-header">
      <view class="intro-icon">💎</view>
      <view class="intro-title">专业顾问为您精选房源</view>
    </view>

    <view class="intro-services">
      <view class="intro-subtitle">我们提供的服务</view>
      <view class="service-list">
        <view class="service-item">
          <view class="service-dot"></view>
          <text class="service-text">1对1专属顾问，全程贴心陪伴</text>
        </view>
        <view class="service-item">
          <view class="service-dot"></view>
          <text class="service-text">定向房源推荐，精准匹配需求</text>
        </view>
        <view class="service-item">
          <view class="service-dot"></view>
          <text class="service-text">专业选房指导，规避投资风险</text>
        </view>
        <view class="service-item">
          <view class="service-dot"></view>
          <text class="service-text">专人拍卖代理，省心省力</text>
        </view>
        <view class="service-item">
          <view class="service-dot"></view>
          <text class="service-text">融资贷款支持，资金无忧</text>
        </view>
      </view>
    </view>

    <view class="intro-promise">
      <view class="intro-subtitle">服务承诺</view>
      <view class="promise-text">📞 电话微信几乎24小时在线响应</view>
      <view class="promise-text">🏆 业内领先的服务能力与服务态度</view>
      <view class="promise-text">🤝 真诚服务每一位客户，让您的法拍之路更顺畅</view>
    </view>

    <view class="intro-tip">
      <view class="tip-icon">💡</view>
      <view class="tip-text">请尽可能留下真实联系方式，以便我们为您提供更及时周到的服务</view>
    </view>
  </view>

  <view class="form-divider"></view>

  <view class="form-group">
    <text class="form-label">姓名 <text class="required">*</text></text>
    <input class="form-input" placeholder="请输入真实姓名（用于客服 1 对 1 联系）" value="{{form.name}}" bindinput="onFieldInput" data-field="name" />
  </view>
  <view class="form-group">
    <text class="form-label">性别 <text class="required">*</text></text>
    <view class="radio-group">
      <view class="radio-item {{form.gender === 1 ? 'active' : ''}}" bindtap="onRadioChange" data-value="1">男</view>
      <view class="radio-item {{form.gender === 2 ? 'active' : ''}}" bindtap="onRadioChange" data-value="2">女</view>
    </view>
  </view>
  <view class="form-group">
    <text class="form-label">手机号 <text class="required">*</text></text>
    <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onFieldInput" data-field="phone" />
  </view>
  <view class="form-group">
    <text class="form-label">居住城市 <text class="required">*</text></text>
    <input class="form-input" placeholder="请输入城市" value="{{form.city}}" bindinput="onFieldInput" data-field="city" />
  </view>
  <view class="form-group">
    <text class="form-label">购房用途 <text class="required">*</text></text>
    <view class="radio-group">
      <view class="radio-item {{form.purpose === '自住' ? 'active' : ''}}" bindtap="onRadioChange" data-field="purpose" data-value="自住">自住</view>
      <view class="radio-item {{form.purpose === '投资' ? 'active' : ''}}" bindtap="onRadioChange" data-field="purpose" data-value="投资">投资</view>
      <view class="radio-item {{form.purpose === '不限' ? 'active' : ''}}" bindtap="onRadioChange" data-field="purpose" data-value="不限">不限</view>
    </view>
  </view>
  <view class="form-group">
    <text class="form-label">购房预算 <text class="required">*</text></text>
    <input class="form-input" placeholder="例如：300-500万" value="{{form.budget}}" bindinput="onFieldInput" data-field="budget" />
  </view>
  <view class="form-group">
    <text class="form-label">自有资金</text>
    <input class="form-input" placeholder="选填" value="{{form.own_funds || ''}}" bindinput="onFieldInput" data-field="own_funds" />
  </view>
  <view class="form-group">
    <text class="form-label">购房区域 <text class="required">*</text></text>
    <input class="form-input" placeholder="请输入意向区域" value="{{form.target_district}}" bindinput="onFieldInput" data-field="target_district" />
  </view>
  <button class="submit-btn btn-primary" bindtap="onSubmit" loading="{{submitting}}">提交需求</button>
</view>
