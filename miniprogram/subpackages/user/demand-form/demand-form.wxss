page {
  background: var(--bg-page);
}

.form-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 80rpx;
}

/* ===== 服务介绍区 ===== */
.service-intro {
  background: linear-gradient(135deg, var(--blue-900) 0%, var(--blue-700) 100%);
  border-radius: var(--radius-md);
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  position: relative;
  overflow: hidden;
}

.service-intro::after {
  content: '';
  position: absolute;
  right: -50rpx;
  top: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255, 107, 53, 0.15) 0%, transparent 70%);
  border-radius: 50%;
  pointer-events: none;
}

.intro-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.intro-icon {
  font-size: 48rpx;
  line-height: 1;
}

.intro-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
  flex: 1;
}

.intro-services {
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.intro-subtitle {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--accent-orange);
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.service-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.service-dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--accent-orange);
  border-radius: 50%;
  flex-shrink: 0;
}

.service-text {
  font-size: 26rpx;
  color: #fff;
  line-height: 1.6;
  letter-spacing: 0.5rpx;
}

.intro-promise {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.promise-text {
  font-size: 24rpx;
  color: var(--blue-100);
  line-height: 2;
  letter-spacing: 0.5rpx;
}

.intro-tip {
  background: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-md);
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  position: relative;
  z-index: 1;
  border: 2rpx solid rgba(255, 107, 53, 0.3);
}

.tip-icon {
  font-size: 32rpx;
  line-height: 1;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: var(--blue-50);
  line-height: 1.7;
  letter-spacing: 0.5rpx;
  flex: 1;
}

.form-divider {
  height: 2rpx;
  background: linear-gradient(90deg, transparent, var(--blue-200), transparent);
  margin: 32rpx 0;
}

.form-page::before {
  content: '说出你的需求，让法拍主理为你 1 对 1 推荐';
  display: block;
  font-size: 28rpx;
  color: var(--blue-700);
  background: linear-gradient(135deg, var(--accent-orange-soft), #fff);
  border-left: 6rpx solid var(--accent-orange);
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  letter-spacing: 0.5rpx;
  display: none; /* 隐藏原有的提示，改用服务介绍区 */
}

.form-group {
  background: var(--bg-card);
  padding: 24rpx 28rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 24rpx;
  color: var(--blue-700);
  margin-bottom: 14rpx;
  display: block;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.required {
  color: var(--accent-orange-text);
  margin-left: 4rpx;
  font-weight: 800;
}

.form-input {
  width: 100%;
  padding: 0 24rpx;
  height: 80rpx;
  border: 2rpx solid transparent;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  background: var(--blue-50);
  color: var(--blue-900);
  box-sizing: border-box;
  transition: all 0.2s;
}

.form-input:focus {
  border-color: var(--accent-orange);
  background: #fff;
}

.radio-group {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.radio-item {
  padding: 14rpx 28rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--blue-700);
  background: var(--blue-50);
  font-weight: 600;
  border: 2rpx solid transparent;
}

.radio-item.active {
  background: var(--blue-900);
  border-color: var(--blue-900);
  color: #fff;
  font-weight: 800;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  margin-top: 32rpx;
  font-size: 30rpx;
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  border-radius: var(--radius-pill);
  color: #fff;
  border: none;
  font-weight: 800;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
}

.submit-btn::after { border: none; }

/* ===== AI 语音说需求 ===== */
.voice-card {
  background: linear-gradient(135deg, var(--blue-900) 0%, var(--blue-700) 100%);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
}

.voice-head {
  margin-bottom: 24rpx;
}

.voice-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1rpx;
  display: block;
}

.voice-sub {
  font-size: 22rpx;
  color: var(--blue-200);
  margin-top: 8rpx;
  display: block;
  line-height: 1.5;
}

.voice-btn {
  height: 96rpx;
  border-radius: var(--radius-pill);
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
}

.voice-btn.recording {
  background: linear-gradient(135deg, #f5365c 0%, #f56036 100%);
  animation: voicePulse 1.2s ease-in-out infinite;
}

@keyframes voicePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(0.98); opacity: 0.92; }
}

.voice-ico {
  width: 36rpx;
  height: 36rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
}

.voice-result {
  margin-top: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-md);
  padding: 20rpx;
}

.vr-label {
  font-size: 22rpx;
  color: var(--blue-200);
  display: block;
  margin-bottom: 12rpx;
}

.vr-text {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  color: #fff;
  line-height: 1.5;
}
