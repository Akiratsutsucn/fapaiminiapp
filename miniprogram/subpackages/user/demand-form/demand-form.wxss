page {
  background: var(--bg-page);
}

.form-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 80rpx;
}

.form-page::before {
  content: '说出你的需求，让法拍主理为你 1 对 1 推荐';
  display: block;
  font-size: 28rpx;
  color: var(--blue-700);
  background: linear-gradient(135deg, var(--accent-orange-soft), #fff);
  border-left: 6rpx solid var(--accent-orange);
  padding: 20rpx 24rpx;
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
  font-weight: 600;
  line-height: 1.5;
  letter-spacing: 0.5rpx;
}

.form-group {
  background: var(--bg-card);
  padding: 24rpx 28rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
}

.form-label {
  font-size: 24rpx;
  color: var(--blue-700);
  margin-bottom: 14rpx;
  display: block;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.required {
  color: var(--accent-orange-text);
  margin-left: 4rpx;
  font-weight: 800;
}

.form-input {
  width: 100%;
  padding: 0 24rpx;
  height: 80rpx;
  border: 2rpx solid transparent;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  background: var(--blue-50);
  color: var(--blue-900);
  box-sizing: border-box;
  transition: all 0.2s;
}

.form-input:focus {
  border-color: var(--accent-orange);
  background: #fff;
}

.radio-group {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.radio-item {
  padding: 14rpx 28rpx;
  border-radius: var(--radius-pill);
  font-size: 24rpx;
  color: var(--blue-700);
  background: var(--blue-50);
  font-weight: 600;
  border: 2rpx solid transparent;
}

.radio-item.active {
  background: var(--blue-900);
  border-color: var(--blue-900);
  color: #fff;
  font-weight: 800;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  margin-top: 32rpx;
  font-size: 30rpx;
  background: linear-gradient(135deg, var(--accent-orange) 0%, var(--accent-orange-2) 100%);
  border-radius: var(--radius-pill);
  color: #fff;
  border: none;
  font-weight: 800;
  letter-spacing: 4rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 53, 0.4);
}

.submit-btn::after { border: none; }
