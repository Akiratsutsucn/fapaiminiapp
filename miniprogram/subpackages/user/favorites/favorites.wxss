.favorites-page {
  background: var(--bg-page);
  min-height: 100vh;
  padding-bottom: 80rpx;
}

.tab-bar {
  display: flex;
  background: var(--bg-card);
  margin: 16rpx 24rpx 0;
  padding: 8rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  font-weight: 600;
  transition: all 0.2s;
}

.tab-item.active {
  color: #fff;
  background: var(--blue-900);
  font-weight: 700;
}

.fav-list {
  padding-top: 8rpx;
}

/* 文章收藏卡 */
.fav-article {
  display: flex;
  gap: 20rpx;
  background: var(--bg-card);
  margin: 16rpx 24rpx;
  padding: 20rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}

.fa-cover {
  width: 200rpx;
  height: 140rpx;
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  background: var(--blue-100);
}

.fa-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.fa-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--blue-900);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.fa-date {
  font-size: 22rpx;
  color: var(--text-hint);
}

.empty-state {
  text-align: center;
  padding: 160rpx 0;
  color: var(--text-hint);
  font-size: 26rpx;
}

.empty-state::before {
  content: '○';
  display: block;
  font-size: 80rpx;
  color: var(--blue-200);
  margin-bottom: 24rpx;
  line-height: 1;
}
