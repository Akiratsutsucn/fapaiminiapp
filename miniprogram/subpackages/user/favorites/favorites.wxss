.favorites-page {
  background: var(--bg-page);
  min-height: 100vh;
  padding-bottom: 80rpx;
}

.tab-bar {
  display: flex;
  background: var(--bg-card);
  margin: 16rpx 24rpx 0;
  padding: 8rpx;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  font-weight: 600;
  transition: all 0.2s;
}

.tab-item.active {
  color: #fff;
  background: var(--blue-900);
  font-weight: 700;
}

.fav-list {
  padding-top: 8rpx;
}

.empty-state {
  text-align: center;
  padding: 160rpx 0;
  color: var(--text-hint);
  font-size: 26rpx;
}

.empty-state::before {
  content: '○';
  display: block;
  font-size: 80rpx;
  color: var(--blue-200);
  margin-bottom: 24rpx;
  line-height: 1;
}
