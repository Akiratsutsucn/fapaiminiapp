page {
  background: var(--bg-page);
}

.history-page {
  min-height: 100vh;
  padding: 16rpx 0 80rpx;
}

.history-list {
  margin: 0 24rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  overflow: hidden;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid rgba(58, 90, 140, 0.06);
  transition: background 0.2s;
}

.history-item:last-child {
  border-bottom: none;
}

.history-item:active {
  background: var(--blue-50);
}

.item-type-icon {
  width: 56rpx;
  height: 56rpx;
  margin-right: 20rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.prop-icon {
  background: linear-gradient(135deg, var(--accent-orange-soft), #fff);
}

.prop-icon::after {
  content: '';
  width: 24rpx;
  height: 22rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
}

.art-icon {
  background: linear-gradient(135deg, var(--blue-50), #fff);
}

.art-icon::after {
  content: '';
  width: 24rpx;
  height: 24rpx;
  background-image: url("data:image/svg+xml;base64,");
  background-size: contain;
  background-repeat: no-repeat;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.item-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--blue-900);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.item-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.item-arrow {
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 12rpx solid var(--blue-300);
  flex-shrink: 0;
}

.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: var(--text-hint);
  font-size: 26rpx;
}

.empty-state::before {
  content: '○';
  display: block;
  font-size: 80rpx;
  color: var(--blue-200);
  margin-bottom: 24rpx;
  line-height: 1;
}
